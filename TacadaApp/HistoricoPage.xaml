<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TacadaApp.HistoricoPage">

    <Grid Padding="20" RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Spacing="20" Margin="0,0,0,20">
            <Label Text="Histórico de Comandas Fechadas" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />

            <Button Text="💾 Exportar Backup" 
                    Clicked="OnExportarBackupClicked" 
                    BackgroundColor="#2196F3" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    CornerRadius="8" />
        </VerticalStackLayout>


        <CollectionView x:Name="ListaHistorico" Grid.Row="1">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,5" Padding="15" BackgroundColor="#2B2B2B" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="5">

                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Identificacao}" FontSize="18" TextColor="White" FontAttributes="Bold" />

                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalConsumido, StringFormat='R$ {0:F2}'}" FontSize="18" TextColor="#4CAF50" FontAttributes="Bold" />

                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding DataFormatada}" FontSize="14" TextColor="Gray" />

                            <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding ResumoProdutos}" FontSize="14" TextColor="#A0A0A0" FontAttributes="Italic" Margin="0,5,0,0"/>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>